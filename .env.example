# Copy to ".env" and fill in your key. The CLI/server auto-load .env.

# ---- Choose a provider and fill in its key ----
# Supported providers: openai, anthropic, groq, deepseek, ollama, gemini, xai,
# and openai_compatible (for another OpenAI-compatible API).
BEACON_LLM_PROVIDER=openai
BEACON_LLM_API_KEY=sk-your-openai-key-here
BEACON_LLM_MODEL=gpt-4o-mini
## Required only with BEACON_LLM_PROVIDER=openai_compatible.
# BEACON_LLM_BASE_URL=https://your-provider.example/v1

# ---- Examples: change the values above; keep your real key private. ----
# Groq:      BEACON_LLM_PROVIDER=groq      / key gsk_...  / model llama-3.3-70b-versatile
# DeepSeek:  BEACON_LLM_PROVIDER=deepseek  / key sk-...   / model deepseek-chat
# Ollama:    BEACON_LLM_PROVIDER=ollama    / (no key)     / model llama3.1   (run `ollama serve`)
# Claude:    BEACON_LLM_PROVIDER=anthropic / key sk-ant-… / model claude-sonnet-4-6
# Gemini:    BEACON_LLM_PROVIDER=gemini    / your Gemini key / model gemini-3.5-flash
# Grok/xAI:  BEACON_LLM_PROVIDER=xai       / your xAI key    / model grok-4.5
